{
  // 딸기로 TIPS 과제 문서(한국어 기획 문서) markdownlint 규칙
  // 기본 규칙 사용 + 한국어 산문/표 스타일에 맞지 않는 규칙만 비활성화
  "default": true,

  // 한국어 산문은 의미 단위로 길게 쓰므로 줄 길이 제한을 두지 않는다
  "MD013": false,

  // 본 프로젝트 표는 의도적으로 compact 스타일(여백 없는 파이프)을 쓴다
  "MD060": false,

  // 동일 문장 안의 중복 강조/구두점은 한국어 문서에서 흔하므로 완화
  "MD037": true
}
